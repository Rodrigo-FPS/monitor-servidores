APP_NAME="Monitor de Servidores"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=monitor_servidores
DB_USERNAME=monitor_app
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=monitor_session
SESSION_SECURE_COOKIE=true

HEARTBEAT_INTERVALO_SEGUNDOS=30
HEARTBEAT_TIMEOUT_SEGUNDOS=90
VENTANA_HMAC_SEGUNDOS=60
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MINUTOS=10
