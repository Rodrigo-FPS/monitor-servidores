APP_NAME="Monitor de Servidores"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=monitor_laravel
DB_USERNAME=laravel_app
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=monitor_session
SESSION_SECURE_COOKIE=true

#cache en disco y colas sincronas: evita necesitar tablas extra de cache/jobs
CACHE_STORE=file
QUEUE_CONNECTION=sync

LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MINUTOS=10

#URL interna del servidor FastAPI y clave de API para las peticiones admin
FASTAPI_URL=http://127.0.0.1:8000
FASTAPI_KEY=
