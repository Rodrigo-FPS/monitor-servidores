#configuracion del demonio de heartbeat
#copiar como: sudo cp config.env.example /etc/monitor-agent/config.env
#aplicar permisos: sudo chmod 600 /etc/monitor-agent/config.env

#debe coincidir exactamente con el server_id registrado en el servidor central
SERVER_ID=nombre-unico-aqui

#debe usar https en produccion (el agente rechaza http salvo PERMITIR_HTTP=1)
SERVER_URL=https://tu-dominio.com

#debe coincidir con HEARTBEAT_INTERVALO_SEGUNDOS del servidor central
INTERVALO_SEGUNDOS=30

#solo para pruebas locales sin TLS: 1 permite SERVER_URL con http://
#en produccion dejar en 0 o no definir
PERMITIR_HTTP=0

#la autenticacion usa Ed25519 — no se necesita ningun secreto aqui
#el agente genera el par de claves automaticamente en el primer arranque:
#  clave privada: /etc/monitor-agent/private.key  (chmod 400)
#  clave publica: /etc/monitor-agent/public.key   (legible)
#copia el contenido de public.key al registrar el servidor en el panel web
