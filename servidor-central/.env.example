# ?ssl=disable es obligatorio cuando el servicio corre con ProtectHome=true (systemd):
# asyncpg intenta leer ~/.postgresql/postgresql.key y el directorio home esta bloqueado.
# Para PostgreSQL local (loopback) el TLS entre app y BD no aporta seguridad adicional.
DATABASE_URL=postgresql+asyncpg://fastapi_app:password@127.0.0.1:5432/monitor_fastapi?ssl=disable

#genera una con: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_API_KEY=reemplaza-esto-con-una-clave-larga-y-aleatoria

#debe coincidir con INTERVALO_SEGUNDOS en la config de los clientes
HEARTBEAT_INTERVALO_SEGUNDOS=30

#recomendado 3x el intervalo de heartbeat
HEARTBEAT_TIMEOUT_SEGUNDOS=90

#ventana antireplay no subir demasiado
VENTANA_ANTIREPLAY_SEGUNDOS=60
