#formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql+asyncpg://monitor_app:password@localhost:5432/monitor_fastapi

#genera una con: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_API_KEY=reemplaza-esto-con-una-clave-larga-y-aleatoria

#debe coincidir con INTERVALO_SEGUNDOS en la config de los clientes
HEARTBEAT_INTERVALO_SEGUNDOS=30

#recomendado 3x el intervalo de heartbeat
HEARTBEAT_TIMEOUT_SEGUNDOS=90

#ventana antireplay no subir demasiado
VENTANA_HMAC_SEGUNDOS=60

#deshabilita /docs
AMBIENTE=produccion
